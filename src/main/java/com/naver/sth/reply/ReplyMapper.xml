<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.naver.sth.reply.ReplyMapper">
  
  <insert id="create" parameterType="ReplyDTO">
  	INSERT INTO "TB_REPLY"
  	VALUES(default,#{username},#{replyContents},now(),#{replyStar},#{productNum})
  	
  </insert>
  
  <select id="list" resultType="ReplyDTO" parameterType="ReplyDTO">
  	SELECT * FROM "TB_REPLY"
  	WHERE "PRODUCT_NUM"=#{productNum}
  	ORDER BY "REPLY_NUM" DESC
  </select>
  
  <delete id="delete" parameterType="ReplyDTO">
  	DELETE FROM "TB_REPLY"
  	WHERE "REPLY_NUM"=#{replyNum}
  </delete>
  
  <update id="update" parameterType="ReplyDTO">
  	UPDATE "TB_REPLY"
  	SET "REPLY_CONTENTS"=#{replyContents},"REPLY_STAR"=#{replyStar}
  	WHERE "REPLY_NUM"=#{replyNum}
  
  </update>
  
  </mapper>