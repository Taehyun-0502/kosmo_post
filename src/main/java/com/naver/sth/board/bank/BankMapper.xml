<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <!-- mapper.java에 풀패키지명.클래스명 -->
  <mapper namespace="com.naver.sth.board.bank.BankMapper">
  	<!-- mapper.java의 메서드 명 -->
  	<sql id="search_sql">
  		WHERE 
  		<choose>
  			<when test="kind=='v2'">
  				"PRODUCT_CONTENTS"
  			</when>
  			<when test="kind=='v3'">
  				"PRODUCT_TYPE"
  			</when>
  			<otherwise>"PRODUCT_TITLE"</otherwise>
  		</choose>
  		LIKE CONCAT('%',#{search},'%')
  	</sql>
  	
  	
  	<select id="list" resultMap="joinResult" parameterType="Pager">

  		SELECT * FROM "TB_BANK" b
  		LEFT JOIN "TB_BANKFILE" bf
  		USING ("PRODUCT_NUM")
  		<include refid="search_sql"></include>
  		ORDER BY "PRODUCT_NUM" DESC 
  		LIMIT #{perPage} OFFSET #{startNum}
  	</select>
 
 		<resultMap type="BankDTO" id="joinResult">
	 		<id column="PRODUCT_NUM" property="productNum"/>
	 		<result column="PRODUCT_TITLE" property="productTitle"/>
 			<result column="PRODUCT_CONTENTS" property="productContents"/>	
 			<result column="PRODUCT_TYPE" property="productType"/>
 			<result column="PRODUCT_RATE" property="productRate"/>
 			
 			<association property="bankFileDTO" javaType="BankFileDTO">
 			<id column="FILE_NUM" property="fileNum"/>
 			<result column="FILE_NAME" property="fileName"/>
 			<result column="ORI_NAME" property="oriName"/>
 			<result column="PRODUCT_NUM" property="productNum"/>
 			
 			</association>
 			
 		</resultMap>
 		
  
  <insert id="create" parameterType="BankDTO" useGeneratedKeys="true" keyProperty="productNum">
  	
  	INSERT INTO "TB_BANK"
  	VALUES (DEFAULT,#{productTitle},#{productContents},#{productType},#{productRate})
  
  </insert>
  <select id="getCount" resultType="Long" parameterType="Pager">
  SELECT COUNT("PRODUCT_NUM")FROM "TB_BANK"
  <include refid="search_sql"></include>
  </select>
  
  <insert id="createFile" parameterType="BankFileDTO">
  	INSERT INTO "TB_BANKFILE"
  	VALUES (DEFAULT,#{fileName},#{oriName},#{productNum})
  
  </insert>
  
  <select id="detail" parameterType="BankDTO" resultMap="joinResult">
  SELECT * FROM "TB_BANK" b
  		LEFT JOIN "TB_BANKFILE" bf
  		USING ("PRODUCT_NUM")
  		WHERE "PRODUCT_NUM"=#{productNum}
  
  
  
  </select>
  
  
  
  
  
  
  </mapper>
